# vSphere MCP Server Configuration
# Copy this file to .env and set appropriate values.

# vCenter Configuration
# One or more vCenter hostnames, comma-separated. The first is the primary/default.
# Inventory tools query ALL of these; VM-targeted tools auto-locate the VM on
# whichever vCenter owns it. All hosts share the credentials below.
VCENTER_HOSTS=vcenter-a.domain.local,vcenter-b.domain.local

# Single-host legacy fallback (used only if VCENTER_HOSTS is unset):
# VCENTER_HOST=vcenter.domain.local

# Shared credentials (used for every host in VCENTER_HOSTS)
VCENTER_USER=username@domain.local
VCENTER_PASSWORD=your_password_here

# SSL Configuration
# INSECURE=True  -> disable SSL certificate verification (common in labs)
# INSECURE=False -> enforce SSL verification (default)
INSECURE=True
